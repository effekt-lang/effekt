  // writeInbox(t1_inbox, 0)
  
  var t1_queue: MessageQueue = allocateQueue()
  var t2_queue: MessageQueue = allocateQueue()

  val t1 = start_thread {
    var state = 0
    loop {
      t1_queue.peek() match {
        case None() => () // no message
        case Some(msg) => {
          t1_queue.dequeue()
          msg match {
            case 0 => {
              println("T1 got okay")
              if (state < 3) {
                println(s"T1 sending ${state.show}")
                t2_queue.enqueue(state)
                state = state + 1
              } else {
                println("T1 is done")
                t2_queue.enqueue(-1)
                do stop()
              }
            }
            case n => println(s"Got unknown message ${n.show}");
          }
        }
      }
    }
  }

  val t2 = start_thread {
    println("Starting T2")
    loop {
      t2_queue.peek() match {
        case None() => () // no message in queue
        case Some(-1) => {
          println("T2 received stop")
          t2_queue.dequeue()
          do stop()
        }
        case Some(n) => {
          println(s"T2 received ${n.show}")
          t2_queue.dequeue()
          t1_queue.enqueue(0)
          ()
        }
      }
    }
  }

  t1_queue.enqueue(0)

  join_thread(t1)
  join_thread(t2)

  freeQueue(t1_queue)
  freeQueue(t2_queue)


  ()
}