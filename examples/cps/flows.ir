def main(k) {
  def f(y) { k(y) }
  def g(x) { x(2) }
  // here f is passed, but to a **known** function
  // so we _could_ adapt parameters
  g(f)
}

/// FLOWS

main
---
y_3 !-> 2
x_5 !-> f_2

/// DROP_PARAMETERS
def main_0(k) {
  def f() {
    k(2)
  }
  def g() {
    f()
  }
  g()
}

/// INLINE
def main(k) {
  k(2)
}
