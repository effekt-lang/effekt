def even(x, ks, k) {
  run tmp = eq(x, 0);
  if (tmp) {
    k(0, ks)
  } else {
    run tmp = sub(x, 1);
    odd(tmp, ks, k)
  }
}
def odd(x, ks, k) {
  run tmp = eq(x, 0);
  if (tmp) {
    k(0, ks)
  } else {
    run tmp = sub(x, 1);
    even(tmp, ks, k)
  }
}
def main(ks, k) {
  even(10, ks, k)
}

/// FLOWS

even
---
{} <: k_5   <: 1st
{} <: ks_4  <: 1st
{} <: tmp_6 <: 1st
{} <: tmp_7 <: 1st
{} <: x_3   <: 1st
