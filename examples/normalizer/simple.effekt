def cond() = false
def main1() = {
    var x = 0
    if (cond()) {
        x = x + 1
    } else {
        x = x + 2
    }
    println(x)
}

def main2() = {
    var x = 0
    val c = cond()
    x = 0
    if (c) {
        x = x + 1
    } else {
        x = x + 2
    }
    println(x)
}

def main3() = {
    region reg {
        def foo(init: Int) {r: Region} = {
            var x in r = init
            x = x + 1
            x
        }
        val y = foo(42) {reg}
        println(y)
    }
}

effect break(): Nothing

def main5() = {
    val x = try {
      def run { prog: (Int) {() => Unit} => Unit }: Unit =
        prog(42) { () => () }
      var y = 1
      run { (v) { f } =>
        y = 2
        println("here")
        do break()
      }
      ()
    } with break {
        ()
    }
    println(x)
}

interface State {
  def get(): Int
  def put(x: Int): Unit
}

def handleState[A] { prog: => A / State }: A = {
    var x = 0
    try prog()
    with State {
        def get() = resume(x)
        def put(y) = {
            x = y
            resume(())
        }
    }
}

def main6() = {
  with handleState
  if (do get() == 0) {
    do put(1)
    do put(do get() + 1)
  } else {
    do put(3)
  }
  println(do get())
}

