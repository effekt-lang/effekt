record Vector3d(x: Double, y: Double, z: Double)

def main7() = {
    val u = Vector3d(1.0, 2.0, 3.0)
    val v = Vector3d(4.0, 5.0, 6.0)
    val res = v.x + v.y + v.z + v.x + v.y + v.z +v.x + v.y + v.z +v.x + v.y + v.z +v.x + v.y
    val res1 = res + v.x + v.y + v.z + v.x + v.y + v.z +v.x + v.y + v.z +v.x + v.y + v.z +v.x + v.y
    val res2 = res1 + v.x + v.y + v.z + v.x + v.y + v.z +v.x + v.y + v.z +v.x + v.y + v.z +v.x + v.y
    val res3 = res2 + v.x + v.y + v.z + v.x + v.y + v.z +v.x + v.y + v.z +v.x + v.y + v.z +v.x + v.y
    println(res3)
}

