def main8() = {
    var x = 1
    def run(f: => Unit at {x}) = f()
    val f = box {
      x = x + 1
    }
    run(f)
    println(x)
}

// boxes

effect Eff(): Unit
def main1() = {
  var x = 0
  try {
    x = 1
    do Eff()
    x = x + 1
  } with Eff { resume(()) }
  println(x)
}

def run() = {
    var y = 0
    def make { f: () => Unit }: () => Unit at {f} = {
      f()
      box { () => f() }
    }
    val f: () => Unit at {y} = make { () =>
      y = y + 1
    }
    def unboxedF = unbox f
    unboxedF()
    println(y)
    /*
    val g = make { () => println("hello") }
    def unboxedG = unbox g
    unboxedG()
    */
}

def main2() = {
    var y = 0
    def makeInc() = {
      box { (c: Int) => y = y + c }
    }
    val inc = makeInc()
    def incer = unbox inc
    inc(1)
    inc(1)
    println(y)
    run()
}

