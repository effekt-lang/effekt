module with_val_else

import stream

def nextOption[T, R] { f: Option[T] => R }: R / next[T] =
  f(try { Some(do next()) } with stop { None() })

def getValue() = {
  with val Some(x) = nextOption[Int, String]() else "<value not found>"
  show(x)
}

def main() =  {
  with [42, 100].feed;
  while (getValue() is v and v != "<value not found>") {
    println("Read value: " ++ v)
  }
}