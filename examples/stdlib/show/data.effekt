type Data {
  Empty()
  Value(x: Int)
  Multiple(a: Char, b: Byte)
  InnerList(l: List[Int])
}

def main() = {
  println(show(Empty()))
  println(show(Value(42)))
  println(show(Multiple('a', 0xAA)))
  println(show(InnerList([1, 2, 3])))
  val a = [InnerList([1, 2, 3]), InnerList([4, 5, 6]), InnerList([7, 8, 9])]
  println(show(a))
}