module custom_map
import list

/*type testList[A]{
  Nil()
  Cons(head: A, tail: testList[A])
  }*/
def main() = {
  inspect(Cons(1,Cons(7,Cons(8,Cons(4,Nil())))).testMap{fib})
}

def fib(n: Int): Int = n match {
  case 0 => 0
  case 1 => 1
  case _ => fib(n - 1) + fib(n - 2)
}



def testMap[A, B](list: List[A]){ fun: A => B}: List[B] =
  list match{
  case Nil() => Nil()
  case Cons(x, xs) => Cons(fun(x), testMap(xs){fun})
}